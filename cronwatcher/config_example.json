{
  "jobs": [
    {
      "name": "database-backup",
      "schedule": "0 2 * * *",
      "command": "/usr/local/bin/backup.sh",
      "timeout": 300
    },
    {
      "name": "log-rotate",
      "schedule": "0 0 * * 0",
      "command": "logrotate /etc/logrotate.conf",
      "timeout": 60
    }
  ],
  "notifier": {
    "smtp_host": "smtp.example.com",
    "smtp_port": 587,
    "sender": "alerts@example.com",
    "recipients": ["ops@example.com"]
  },
  "webhooks": [
    {
      "url": "https://hooks.example.com/cronwatcher",
      "method": "POST",
      "secret": "changeme",
      "timeout": 10
    },
    {
      "url": "https://hooks.slack.com/services/XXX/YYY/ZZZ",
      "method": "POST",
      "timeout": 8
    }
  ],
  "retention": {
    "max_records": 500,
    "max_age_days": 30
  }
}
